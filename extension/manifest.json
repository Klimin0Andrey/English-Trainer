{
  "manifest_version": 3,
  "name": "English Trainer - Add Words",
  "version": "1.0.0",
  "description": "Add words to your English Trainer vocabulary directly from any webpage",
  
  "permissions": [
    "storage",
    "activeTab",
    "contextMenus",
    "notifications",
    "scripting"
  ],
  
  "host_permissions": [
    "https://english-trainer-rg8f.onrender.com/*"
  ],
  
  "background": {
    "service_worker": "background.js"
  },
  
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}